# Server Configuration
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5174

# Database Configuration  
MONGO_URI=mongodb://localhost:27017/erp-hrms
DB_NAME=erp-hrms

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_change_this_in_production
JWT_ACCESS_EXPIRY=30d
JWT_REFRESH_EXPIRY=90d

# Email Service Configuration (Gmail SMTP)
EMAIL_SERVICE=gmail
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-app-password  # Use App Password (not regular password) for Gmail
EMAIL_FROM_NAME=HRMS Task Management System

# Socket.IO Configuration
SOCKET_IO_PORT=5000
SOCKET_IO_COR_ORIGINS=http://localhost:5174
SOCKET_IO_PATH=/socket.io

# Frontend Configuration
FRONTEND_URL=http://localhost:5174
FRONTEND_PORT=5174

# AWS Configuration (if using S3 for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=ap-south-1

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Timezone
TIMEZONE=Asia/Kolkata
