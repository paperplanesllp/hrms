# Google Maps API Key
# Get from: https://console.cloud.google.com/
# 1. Create new project
# 2. Enable "Maps JavaScript API"
# 3. Create API Key in Credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# API Base URL
VITE_API_BASE_URL=http://localhost:5000/api

# Optional explicit server URL for Socket.IO/media URLs
VITE_SERVER_URL=http://localhost:5000

# Optional explicit realtime endpoint (if different from VITE_SERVER_URL)
VITE_SOCKET_URL=http://localhost:5000

# Optional socket path for reverse proxies (examples: /socket.io or /api/socket.io)
VITE_SOCKET_PATH=/socket.io

# Optional TURN server (required for reliable calls across strict NAT/mobile networks)
# Supports one URL or comma-separated URLs, for example:
# VITE_TURN_URL=turn:turn.example.com:3478,turns:turn.example.com:5349
# VITE_TURN_USERNAME=your_turn_username
# VITE_TURN_CREDENTIAL=your_turn_password

# Optional: Enable debug logs
VITE_DEBUG=false

# Optional default city used by dashboard weather widget
# Used when geolocation is unavailable/blocked
# Example: Kochi, Bengaluru, Mumbai
# VITE_WEATHER_DEFAULT_CITY=Kochi
