# Server Configuration
PORT=5000
NODE_ENV=development

# Database - MongoDB URI
MONGO_URI=mongodb://localhost:27017/erp_db

# JWT Secrets
ACCESS_TOKEN_SECRET=your_access_token_secret_key_change_this
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_change_this
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# CORS
CLIENT_ORIGIN=http://localhost:5173,https://thehrsaathi.com,https://www.thehrsaathi.com
SOCKET_IO_PATH=/socket.io/

# Cookies
COOKIE_SECURE=false

# Super Admin (hidden panel)
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=change_this_password
SUPERADMIN_ENABLED=false
SUPERADMIN_ALLOWED_IPS=

# Cloudinary (profile images)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_PROFILE_FOLDER=hrms/profile-images
CLOUDINARY_CHAT_FOLDER=hrms/chat-media

# Temporary login OTP now uses email (SMTP config above)
# No SMS provider configuration is required.

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

 #Loging Details;-

# USer:-Joo@gmail.com(1-8)
# Admin-Admin@gmail.com(1-8)
#HR:-hr@gmail.com(1-8)
