# Server Configuration
PORT=5001
NODE_ENV=development

# Database - MongoDB URI
MONGO_URI=mongodb://localhost:27017/erp_db

# JWT Secrets
ACCESS_TOKEN_SECRET=your_access_token_secret_key_change_this
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_change_this
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# CORS
CLIENT_ORIGIN=http://localhost:3000

# Cookies
COOKIE_SECURE=false

# Cloudinary (profile images)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_PROFILE_FOLDER=hrms/profile-images

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

 #Loging Details;-

# USer:-Joo@gmail.com(1-8)
# Admin-Admin@gmail.com(1-8)
#HR:-hr@gmail.com(1-8)